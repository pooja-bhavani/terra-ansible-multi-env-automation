<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Terra · Ansible Multi-Env Automation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap');

  :root{
    --bg:#060708;
    --panel:#0c0e10;
    --line:#1c2024;
    --line-2:#2a3036;
    --ink:#e8eaed;
    --muted:#8b949e;
    --dim:#5b636b;
    --gold:#e8b94a;
    --gold-glow:rgba(232,185,74,.55);
    --tf:#7b42bc;        /* terraform purple */
    --ans:#cc2936;       /* ansible red */
    --aws:#ff9900;       /* aws orange */
    --blue:#4493f8;
    --green:#3fb950;
    --radius:14px;
  }

  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    margin:0;background:var(--bg);color:var(--ink);
    font-family:"Space Grotesk",system-ui,sans-serif;
    -webkit-font-smoothing:antialiased;line-height:1.5;
    overflow-x:hidden;
  }
  body::before{
    content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
    background:
      radial-gradient(900px 500px at 15% -5%,rgba(123,66,188,.10),transparent 60%),
      radial-gradient(800px 500px at 95% 8%,rgba(255,153,0,.07),transparent 60%),
      radial-gradient(700px 600px at 50% 110%,rgba(68,147,248,.06),transparent 60%);
  }
  .wrap{position:relative;z-index:1;max-width:1240px;margin:0 auto;padding:0 28px}
  .mono{font-family:"JetBrains Mono",monospace}

  /* ---------- HEADER ---------- */
  header{
    position:sticky;top:0;z-index:50;
    background:rgba(6,7,8,.72);backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line);
  }
  .nav{display:flex;align-items:center;gap:14px;height:62px}
  .brand{display:flex;align-items:center;gap:11px;font-weight:600;letter-spacing:.2px}
  .brand .dot{width:11px;height:11px;border-radius:3px;background:var(--gold);
    box-shadow:0 0 14px var(--gold-glow);}
  .nav .spacer{flex:1}
  .nav a.lnk{color:var(--muted);text-decoration:none;font-size:13.5px;padding:6px 10px;border-radius:8px;transition:.2s}
  .nav a.lnk:hover{color:var(--ink);background:var(--panel)}
  .ghbtn{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--ink);
    text-decoration:none;border:1px solid var(--line-2);padding:8px 14px;border-radius:9px;
    background:var(--panel);transition:.2s}
  .ghbtn:hover{border-color:var(--gold);box-shadow:0 0 18px rgba(232,185,74,.18)}

  /* ---------- HERO ---------- */
  .hero{padding:74px 0 30px;text-align:center}
  .eyebrow{display:inline-flex;align-items:center;gap:9px;font-size:12px;letter-spacing:.16em;
    text-transform:uppercase;color:var(--gold);border:1px solid rgba(232,185,74,.28);
    padding:6px 13px;border-radius:100px;background:rgba(232,185,74,.05)}
  .eyebrow .pulse{width:7px;height:7px;border-radius:50%;background:var(--gold);
    box-shadow:0 0 8px var(--gold-glow);animation:pulse 2s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
  h1{font-size:clamp(34px,6vw,62px);line-height:1.04;margin:24px auto 0;max-width:14ch;
    font-weight:700;letter-spacing:-.02em}
  h1 .accent{background:linear-gradient(120deg,var(--gold),#ffd98a);-webkit-background-clip:text;
    background-clip:text;color:transparent}
  .sub{max-width:62ch;margin:22px auto 0;color:var(--muted);font-size:17px}
  .stack{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:30px}
  .chip{font-size:12.5px;color:var(--ink);background:var(--panel);border:1px solid var(--line);
    padding:7px 13px;border-radius:8px;display:inline-flex;align-items:center;gap:8px}
  .chip .d{width:8px;height:8px;border-radius:2px}

  /* ---------- SECTION SHELL ---------- */
  section{padding:56px 0;position:relative}
  .seclabel{display:flex;align-items:center;gap:14px;margin-bottom:8px}
  .seclabel .num{font-family:"JetBrains Mono",monospace;color:var(--gold);font-size:13px}
  .seclabel .ln{height:1px;flex:1;background:linear-gradient(90deg,var(--line-2),transparent)}
  h2{font-size:clamp(24px,3.5vw,34px);margin:0 0 6px;font-weight:600;letter-spacing:-.01em}
  .lead{color:var(--muted);max-width:64ch;font-size:16px;margin:0 0 30px}

  /* ---------- DIAGRAM ---------- */
  .diagram-shell{
    border:1px solid var(--line);border-radius:18px;background:
      linear-gradient(180deg,#0a0b0d,#070809);
    padding:8px;box-shadow:0 30px 80px -40px rgba(0,0,0,.9);overflow:hidden;
  }
  .diagram-shell .bar{display:flex;align-items:center;gap:7px;padding:11px 14px}
  .diagram-shell .bar i{width:11px;height:11px;border-radius:50%;display:inline-block;background:#2a3036}
  .diagram-shell .bar .t{margin-left:10px;font-size:12px;color:var(--dim);font-family:"JetBrains Mono",monospace}
  .svgwrap{position:relative;width:100%;background:#050607;border-radius:12px;overflow:hidden}
  svg.flow{width:100%;height:auto;display:block}

  .legend{display:flex;gap:18px;flex-wrap:wrap;justify-content:center;margin-top:18px;font-size:12.5px;color:var(--muted)}
  .legend span{display:inline-flex;align-items:center;gap:8px}
  .legend .sw{width:22px;height:3px;border-radius:2px;display:inline-block}
  .legend .flowdot{width:9px;height:9px;border-radius:50%;background:var(--gold);box-shadow:0 0 9px var(--gold-glow)}

  /* ---------- ENV TABLE ---------- */
  .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .envcard{border:1px solid var(--line);border-radius:var(--radius);background:var(--panel);
    padding:22px;position:relative;overflow:hidden;transition:.25s}
  .envcard:hover{border-color:var(--line-2);transform:translateY(-3px)}
  .envcard::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;opacity:.9}
  .envcard.dev::before{background:linear-gradient(90deg,var(--green),transparent)}
  .envcard.stag::before{background:linear-gradient(90deg,var(--gold),transparent)}
  .envcard.prod::before{background:linear-gradient(90deg,var(--ans),transparent)}
  .envcard .name{font-family:"JetBrains Mono",monospace;font-size:14px;letter-spacing:.05em;
    display:flex;align-items:center;gap:9px;text-transform:uppercase}
  .envcard .name .led{width:8px;height:8px;border-radius:50%}
  .dev .led{background:var(--green);box-shadow:0 0 9px rgba(63,185,80,.6)}
  .stag .led{background:var(--gold);box-shadow:0 0 9px var(--gold-glow)}
  .prod .led{background:var(--ans);box-shadow:0 0 9px rgba(204,41,54,.6)}
  .envcard .res{display:flex;gap:20px;margin-top:18px}
  .envcard .res div{display:flex;flex-direction:column;gap:2px}
  .envcard .res .v{font-size:30px;font-weight:700;line-height:1;font-family:"JetBrains Mono",monospace}
  .envcard .res .k{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em}

  /* ---------- PROBLEM / SOLUTION ---------- */
  .ps{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  .pscol{border:1px solid var(--line);border-radius:var(--radius);background:var(--panel);overflow:hidden}
  .pscol .hd{padding:16px 20px;font-weight:600;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:10px;font-size:15px}
  .pscol.bad .hd{color:#ff9a9a}
  .pscol.good .hd{color:#a7e6b0}
  .pscol ul{list-style:none;margin:0;padding:8px 0}
  .pscol li{padding:13px 20px;font-size:14.5px;color:var(--muted);border-bottom:1px solid rgba(28,32,36,.6);
    display:flex;gap:12px;align-items:flex-start}
  .pscol li:last-child{border-bottom:0}
  .pscol li b{color:var(--ink);font-weight:600}
  .pscol li .ic{flex-shrink:0;margin-top:1px;font-family:"JetBrains Mono",monospace}
  .bad .ic{color:var(--ans)} .good .ic{color:var(--green)}

  /* ---------- WHY TABLE ---------- */
  .tbl{border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;background:var(--panel)}
  .trow{display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid var(--line)}
  .trow:last-child{border-bottom:0}
  .trow:hover{background:rgba(255,255,255,.015)}
  .trow .tool{padding:15px 20px;font-weight:600;font-size:14.5px;display:flex;align-items:center;gap:10px;border-right:1px solid var(--line)}
  .trow .desc{padding:15px 20px;font-size:14px;color:var(--muted)}
  .trow .tool .tg{width:7px;height:18px;border-radius:3px;flex-shrink:0}

  /* ---------- STEPS ---------- */
  .steps{position:relative;margin-left:8px}
  .steps::before{content:"";position:absolute;left:17px;top:8px;bottom:8px;width:2px;
    background:linear-gradient(180deg,var(--gold),rgba(232,185,74,.1))}
  .step{display:grid;grid-template-columns:38px 1fr;gap:20px;padding:0 0 26px;position:relative}
  .step .node{width:36px;height:36px;border-radius:50%;background:var(--bg);border:2px solid var(--gold);
    display:flex;align-items:center;justify-content:center;font-family:"JetBrains Mono",monospace;
    font-size:14px;font-weight:700;color:var(--gold);z-index:2;box-shadow:0 0 16px rgba(232,185,74,.18)}
  .step .body{padding-top:4px}
  .step .body h4{margin:6px 0 8px;font-size:16px}
  .code{background:#08090a;border:1px solid var(--line);border-radius:10px;padding:14px 16px;
    font-family:"JetBrains Mono",monospace;font-size:13px;color:#c9d1d9;overflow-x:auto;line-height:1.7}
  .code .c{color:var(--dim)}
  .code .g{color:var(--green)}
  .code .y{color:var(--gold)}
  .code .p{color:#c08bff}

  /* ---------- SECRETS ---------- */
  .secrets{display:grid;grid-template-columns:1.1fr .9fr;gap:24px;align-items:center}
  .secrets .panel-card{border:1px solid var(--line);border-radius:var(--radius);background:var(--panel);padding:24px}
  .secrets ul{margin:0;padding-left:0;list-style:none}
  .secrets li{padding:11px 0;border-bottom:1px solid rgba(28,32,36,.7);font-size:14.5px;color:var(--muted);display:flex;gap:12px}
  .secrets li:last-child{border:0}
  .secrets li .k{color:var(--gold);font-family:"JetBrains Mono",monospace;flex-shrink:0}
  .principle{border:1px solid rgba(232,185,74,.3);background:rgba(232,185,74,.04);border-radius:var(--radius);
    padding:22px;font-size:15px}
  .principle .pl{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.14em;
    text-transform:uppercase;color:var(--gold);margin-bottom:10px}

  /* ---------- FOOTER ---------- */
  footer{border-top:1px solid var(--line);padding:40px 0 60px;margin-top:30px;text-align:center;color:var(--dim);font-size:13px}
  footer a{color:var(--muted);text-decoration:none}
  footer a:hover{color:var(--gold)}

  /* ---------- LOGO CHIPS ---------- */
  .chip svg{width:16px;height:16px;display:block}
  .chip{transition:.2s}
  .chip:hover{border-color:var(--line-2);transform:translateY(-2px)}

  /* ---------- AMBIENT GRID TEXTURE ---------- */
  .grid-tex{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.35;
    background-image:
      linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),
      linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);
    background-size:54px 54px;
    mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,#000 30%,transparent 75%);
    -webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,#000 30%,transparent 75%);}

  /* ---------- HERO ORBIT VISUAL ---------- */
  .hero-visual{position:relative;width:280px;height:280px;margin:34px auto 4px}
  .orbit{position:absolute;inset:0;border:1px solid rgba(255,255,255,.06);border-radius:50%}
  .orbit.o1{inset:42px}
  .orbit.o2{inset:0}
  .spin{position:absolute;inset:0;animation:spin 26s linear infinite}
  .spin.rev{animation-direction:reverse;animation-duration:34s}
  @keyframes spin{to{transform:rotate(360deg)}}
  .orb-node{position:absolute;top:-22px;left:50%;transform:translateX(-50%);
    width:44px;height:44px;border-radius:11px;background:#0c0e10;border:1px solid var(--line-2);
    display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(0,0,0,.6)}
  .orb-node svg{width:24px;height:24px}
  .hero-core{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:96px;height:96px;border-radius:24px;
    background:radial-gradient(circle at 30% 25%,#16191d,#0a0b0d);
    border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;
    box-shadow:0 0 60px rgba(232,185,74,.12),inset 0 0 0 1px rgba(232,185,74,.06)}
  .hero-core .ico{width:46px;height:46px}
  .hero-core::after{content:"";position:absolute;inset:-2px;border-radius:24px;
    background:conic-gradient(from 0deg,transparent,rgba(232,185,74,.35),transparent 30%);
    animation:spin 6s linear infinite;z-index:-1;filter:blur(2px)}

  /* ---------- STAT STRIP ---------- */
  .stat-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:0;
    border:1px solid var(--line);border-radius:var(--radius);background:var(--panel);
    margin-top:42px;overflow:hidden}
  .stat-strip .st{padding:22px 20px;text-align:center;border-right:1px solid var(--line);position:relative}
  .stat-strip .st:last-child{border-right:0}
  .stat-strip .st .num{font-family:"JetBrains Mono",monospace;font-size:30px;font-weight:700;
    background:linear-gradient(120deg,var(--gold),#ffd98a);-webkit-background-clip:text;
    background-clip:text;color:transparent;line-height:1}
  .stat-strip .st .lbl{font-size:11.5px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;margin-top:8px}

  /* env card watermark icon */
  .envcard .wm{position:absolute;right:-10px;bottom:-14px;width:90px;height:90px;opacity:.05;pointer-events:none}
  .envcard .wm svg{width:100%;height:100%}

  /* why-tool logo cell */
  .trow .tool .lg{width:20px;height:20px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
  .trow .tool .lg svg{width:18px;height:18px}

  /* pipeline ribbon */
  .ribbon{display:flex;align-items:center;gap:0;flex-wrap:wrap;justify-content:center;
    margin:34px 0 0;padding:18px;border:1px dashed var(--line-2);border-radius:var(--radius);
    background:rgba(255,255,255,.012)}
  .ribbon .pill{display:inline-flex;align-items:center;gap:8px;font-size:12.5px;color:var(--ink);
    padding:8px 14px;border-radius:100px;background:#0c0e10;border:1px solid var(--line)}
  .ribbon .pill svg{width:15px;height:15px}
  .ribbon .arr{color:var(--gold);margin:0 6px;font-size:14px;opacity:.7}

  @media(max-width:860px){
    .grid3,.ps,.secrets,.trow{grid-template-columns:1fr}
    .trow .tool{border-right:0;border-bottom:1px solid var(--line)}
    .nav a.lnk{display:none}
    .stat-strip{grid-template-columns:1fr 1fr}
    .stat-strip .st:nth-child(2){border-right:0}
    .stat-strip .st:nth-child(1),.stat-strip .st:nth-child(2){border-bottom:1px solid var(--line)}
  }
  @media(prefers-reduced-motion:reduce){
    .flowpkt,.pulse,.dash,.spin,.hero-core::after{animation:none !important}
  }
</style>
</head>
